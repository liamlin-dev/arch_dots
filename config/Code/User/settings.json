{
  "workbench.settings.editor": "json",
  "workbench.activityBar.location": "top",
  "workbench.editor.showTabs": "multiple",
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  "breadcrumbs.enabled": false,
  "workbench.sideBar.location": "right",
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "explorer.decorations.badges": false,
  "window.zoomLevel": 1,
  "window.titleBarStyle": "custom",
  "editor.scrollbar.vertical": "hidden",
  "editor.scrollbar.horizontal": "hidden",
  "workbench.tree.enableStickyScroll": false,
  "workbench.tree.renderIndentGuides": "none",
  "workbench.tree.indent": 8,
  "explorer.compactFolders": false,
  "git.decorations.enabled": false,
  "editor.minimap.enabled": true,
  "editor.tabSize": 2,
  "editor.lineHeight": 22,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.guides.bracketPairs": false,
  "editor.linkedEditing": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.acceptSuggestionOnEnter": "off",
  "editor.lineNumbers": "relative",
  "editor.stickyScroll.enabled": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.mouseWheelZoom": true,
  "editor.largeFileOptimizations": true,
  "editor.cursorBlinking": "solid",
  "editor.cursorStyle": "line",
  "editor.smoothScrolling": false, // 平滑滾動
  "editor.cursorSmoothCaretAnimation": "off", // 游標動畫
  "workbench.list.smoothScrolling": false, // 側邊欄平滑滾動
  "terminal.integrated.smoothScrolling": false, // 終端機平滑滾動
  "editor.inlineSuggest.suppressSuggestions": true,
  "editor.guides.indentation": true,
  "editor.semanticHighlighting.enabled": true,
  "editor.inlayHints.enabled": "on",
  "editor.inlineSuggest.enabled": true,
  "editor.snippetSuggestions": "inline",
  "editor.suggest.matchOnWordStartOnly": false,
  "editor.suggest.shareSuggestSelections": true,
  "editor.suggest.showStatusBar": true,
  "editor.suggestOnTriggerCharacters": true,
  "editor.suggestSelection": "first",
  "editor.wordBasedSuggestions": "matchingDocuments",
  "editor.autoClosingOvertype": "always",
  "editor.quickSuggestionsDelay": 0,
  "editor.parameterHints.enabled": true,
  // -------------------------- themes ----------------------------------
  "workbench.colorTheme": "Catppuccin Macchiato",
  "workbench.iconTheme": "symbols",
  // -------------------------- fonts ------------------------------------
  "editor.fontFamily": "'JetBrainsMono Nerd Font','LXGW WenKai Mono TC','CaskaydiaCove Nerd Font'",
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font','LXGW WenKai Mono TC','CaskaydiaCove Nerd Font'",
  "editor.fontSize": 12,
  "terminal.integrated.fontSize": 12,
  "editor.fontLigatures": false,
  "catppuccin.italicKeywords": false,
  "catppuccin.italicComments": false,
  // ---------------------------- exclude files -------------------------------------
  "files.exclude": {
    "**/obj": true,
    "**/bin": false,
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/node_modules": true
  },
  "files.watcherExclude": {
    "**/node_modules/*": true,
    "**/.git/objects/**": true,
    "**/dist/**": true,
    "**/build/**": true
  },
  // ---------------------------- search -----------------------------------
  "search.showLineNumbers": true,
  "search.smartCase": true,
  // ---------------------------- Misc -------------------------------------
  "files.trimTrailingWhitespace": true,
  "security.workspace.trust.untrustedFiles": "open",
  // ---------------------------- backedn-end-------------------------------------
  // python
  "python.analysis.typeCheckingMode": "strict",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.tabSize": 4,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  // C/C++

  // Clangd 參數 (優化性能)
  "clangd.arguments": [
    "--background-index",
    "--clang-tidy",
    "--completion-style=detailed",
    "--header-insertion=iwyu",
    "--function-arg-placeholders",
    "--fallback-style=llvm",
    "--log=verbose",
    "-j=4" // 根據你的 CPU 核心數調整
  ],
  "[cpp]": {
    "editor.tabSize": 2,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  // Git
  "git.autofetch": true,
  "git.mergeEditor": true,
  "symbols.hidesExplorerArrows": false
}
