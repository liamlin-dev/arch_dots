{
  "workbench.settings.editor": "json",
  "workbench.activityBar.location": "top",
  "workbench.editor.showTabs": "single",
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  "breadcrumbs.enabled": false,
  "workbench.sideBar.location": "right",
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "explorer.decorations.badges": false,
  "window.zoomLevel": 1,
  "window.titleBarStyle": "custom",
  "editor.scrollbar.vertical": "hidden",
  "editor.scrollbar.horizontal": "hidden",
  "workbench.tree.enableStickyScroll": false,
  "workbench.tree.renderIndentGuides": "none",
  "workbench.editor.showIcons": true,
  "editor.renderLineHighlight": "all",
  "workbench.tree.indent": 8,
  "explorer.compactFolders": false,
  "git.decorations.enabled": false,
  "editor.minimap.enabled": true,
  "editor.tabSize": 2,
  "editor.lineHeight": 22,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.guides.bracketPairs": false,
  "editor.linkedEditing": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.acceptSuggestionOnEnter": "off",
  "editor.lineNumbers": "relative",
  "editor.stickyScroll.enabled": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.mouseWheelZoom": true,
  "editor.largeFileOptimizations": true,
  "editor.cursorBlinking": "solid",
  "editor.cursorStyle": "line",
  "editor.smoothScrolling": false, // 平滑滾動
  "editor.cursorSmoothCaretAnimation": "off", // 游標動畫
  "workbench.list.smoothScrolling": false, // 側邊欄平滑滾動
  "editor.inlineSuggest.suppressSuggestions": true,
  "editor.guides.indentation": true,
  "editor.semanticHighlighting.enabled": true,
  "editor.inlayHints.enabled": "on",
  "editor.inlineSuggest.enabled": true,
  "editor.snippetSuggestions": "inline",
  "editor.suggest.matchOnWordStartOnly": false,
  "editor.suggest.shareSuggestSelections": true,
  "editor.suggest.showStatusBar": true,
  "editor.suggestOnTriggerCharacters": true,
  "editor.suggestSelection": "first",
  "editor.wordBasedSuggestions": "matchingDocuments",
  "editor.autoClosingOvertype": "always",
  "editor.quickSuggestionsDelay": 0,
  "editor.parameterHints.enabled": true,
  // -------------------------- terminal --------------------------------
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.gpuAcceleration": "on", // 確保終端機渲染夠快
  "terminal.integrated.rightClickBehavior": "paste",
  "terminal.integrated.smoothScrolling": false, // 終端機平滑滾動
  // -------------------------- themes ----------------------------------
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.iconTheme": "symbols",
  // -------------------------- fonts ------------------------------------
  "editor.fontFamily": "'JetBrainsMono Nerd Font','LXGW WenKai Mono TC','CaskaydiaCove Nerd Font'",
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font','LXGW WenKai Mono TC','CaskaydiaCove Nerd Font'",
  "editor.fontSize": 12,
  "terminal.integrated.fontSize": 12,
  "editor.fontLigatures": false,
  "catppuccin.italicKeywords": false,
  "catppuccin.italicComments": false,
  // ---------------------------- exclude files -------------------------------------
  "files.exclude": {
    "**/obj": true,
    "**/bin": false,
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
  },
  "files.watcherExclude": {
    "**/node_modules/*": true,
    "**/.git/objects/**": true,
    "**/dist/**": true,
    "**/build/**": true,
  },
  "search.exclude": {
    "**/build/**": true,
    "**/dist/**": true,
    "**/*.o": true,
    "**/*.a": true,
    "**/*.so": true,
  },
  // ---------------------------- search -----------------------------------
  "search.showLineNumbers": true,
  "search.smartCase": true,
  // ---------------------------- Misc -------------------------------------
  "files.trimTrailingWhitespace": true,
  "security.workspace.trust.untrustedFiles": "open",
  // ---------------------------- Vim --------------------------------------
  "keyboard.dispatch": "keyCode", // 這必須要設置，不然 vscode 讀不到系統的 remap
  "vim.easymotion": false,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.leader": "",
  "vim.handleKeys": {
    "<C-a>": true,
    "<C-f>": true,
  },
  // To improve performance
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1,
  },
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "<Esc>"
      ],
      "commands": [
        ":nohl"
      ],
    },
  ],
  "vim.insertModeKeyBindings": [],
  // ---------------------------- debug ----------------------------------
  "debug.console.fontSize": 12,
  "debug.console.wordWrap": true,
  "debug.inlineValues": "on", // 偵錯時直接在代碼旁邊顯示變數值
  "debug.focusEditorOnBreak": true,
  // ---------------------------- Lang -------------------------------------
  // python
  "python.analysis.typeCheckingMode": "strict",
  "python.analysis.autoImportCompletions": true,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.tabSize": 4,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit",
    },
  },
  // C/C++
  // Clangd 參數 (優化性能)
  "clangd.path": "clangd",
  "clangd.arguments": [
    "--background-index",
    "--clang-tidy",
    "--completion-style=detailed",
    "--header-insertion=iwyu",
    "--function-arg-placeholders",
    "--fallback-style=llvm",
    "--log=verbose",
    "-j=4", // 根據你的 CPU 核心數調整
  ],
  "[cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
    "editor.tabSize": 2,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
    },
  },
  "cmake.useCMakePresets": "always",
  // shell
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
  },
  // Git
  "git.autofetch": true,
  "git.mergeEditor": true,
  "symbols.hidesExplorerArrows": false,
}
